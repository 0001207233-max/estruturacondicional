alert("Escolha o tipo de conversão:");
alert ("1 - Converter de Celsius para Fahrenheit");
alert("2 - Converter de Fahrenheit para Celsius");
alert ("3 - Converter de Celsius para Kelvin");

let opcao = parseInt(prompt("Digite a opção desejada:"));
let temp, convertido;

switch (opcao) {
    case 1:
        temp = parseFloat(prompt("Digite a temperatura em Celsius:"));
        convertido = (temp * 9) / 5 + 32;
        alert (`Resultado: ${temp}°C é igual a ${convertido.toFixed(2)}°F`);
        break;
    case 2:
        temp = parseFloat(prompt("Digite a temperatura em Fahrenheit:"));
        convertido = ((temp - 32) * 5) / 9;
        alert(`Resultado: ${temp}°F é igual a ${convertido.toFixed(2)}°C`);
        break;
    case 3:
        temp = parseFloat(prompt("Digite a temperatura em Celsius:"));
        convertido = temp + 273.15;
        alert (`Resultado: ${temp}°C é igual a ${convertido.toFixed(2)}K`);
        break;
    default:
        alert ("Opção inválida!");
}
